# =============================================================
# Lunovel / KomikKu — environment variables
# =============================================================
# Copy this file to `.env.local` and fill in the values you need.
# Empty values = feature disabled.

# -------------------------------------------------------------
# Supabase (optional — leave empty to use local JSON data)
# Set both URL and ANON_KEY to enable Supabase-backed storage
# (covers novels, chapters, bookmarks, history, AND comments).
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -------------------------------------------------------------
# Vercel KV / Upstash Redis (optional — comment storage fallback)
# Set both to store comments in Redis instead of Supabase.
# Get these from: Vercel dashboard → Storage → KV → Connect
# -------------------------------------------------------------
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (legacy Upstash names also accepted)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# -------------------------------------------------------------
# Site
# -------------------------------------------------------------
NEXT_PUBLIC_SITE_NAME=KomikKu
NEXT_PUBLIC_SITE_URL=http://localhost:3000